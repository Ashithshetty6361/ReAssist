# ═══════════════════════════════════════════════════════════════════════════════
# ReAssist Environment Configuration
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════════════════════

# Required — OpenAI API key for LLM calls
OPENAI_API_KEY=your_openai_api_key_here

# Optional — Tavily API key for web search fallback
TAVILY_API_KEY=your_tavily_api_key_here

# Optional — Model to use (default: gpt-3.5-turbo)
MODEL_NAME=gpt-3.5-turbo

# Optional — Max papers per search (default: 7)
MAX_PAPERS=7

# Optional — Database URL (default: sqlite:///reassist.db)
# For production Postgres: postgresql://user:pass@host:5432/reassist
DATABASE_URL=sqlite:///reassist.db

# Optional — JWT secret for auth tokens (auto-generated if not set)
JWT_SECRET=change_this_to_a_random_secret_string
